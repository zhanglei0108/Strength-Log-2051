<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Strength_Log.WorkoutHistoryPage"
             Title="Workout History"
             BackgroundColor="#F5F5F5">

    <Grid Padding="20" RowSpacing="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Label Grid.Row="0"
               Text="Workout History"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               TextColor="Black" />

        <SearchBar Grid.Row="1"
                   Placeholder="Search by date"
                   TextChanged="OnSearchTextChanged"
                   Margin="0,10,0,10"
                   BackgroundColor="White"
                   PlaceholderColor="Gray"
                   TextColor="Black" />

        <Label Grid.Row="2"
               x:Name="NoResultLabel"
               Text="No matching workout found"
               TextColor="Red"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               IsVisible="False"
               Margin="0,5,0,5" />

        <CollectionView Grid.Row="3"
                        x:Name="WorkoutCollectionView"
                        Margin="0,10,0,0"
                        VerticalOptions="FillAndExpand">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,6,0,6"
                            Padding="12"
                            BackgroundColor="White"
                            StrokeThickness="1"
                            Stroke="#DDDDDD">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>

                        <Grid ColumnDefinitions="*,Auto">

                            <VerticalStackLayout Grid.Column="0" Spacing="4">

                                <Label Text="{Binding ExerciseType}"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       TextColor="Black" />

                                <Label Text="{Binding Sets, StringFormat='Sets: {0}'}"
                                       FontSize="15"
                                       TextColor="Black" />

                                <Label Text="{Binding Reps, StringFormat='Reps: {0}'}"
                                       FontSize="15"
                                       TextColor="Black" />

                                <Label Text="{Binding Weight, StringFormat='Weight: {0} kg'}"
                                       FontSize="15"
                                       TextColor="Black" />

                                <Label Text="{Binding DateText, StringFormat='Date: {0}'}"
                                       FontSize="15"
                                       TextColor="Gray" />

                            </VerticalStackLayout>

                            <Button Grid.Column="1"
                                    Text="Delete"
                                    Clicked="OnDeleteWorkoutClicked"
                                    CommandParameter="{Binding .}"
                                    FontSize="12"
                                    HeightRequest="32"
                                    WidthRequest="70"
                                    CornerRadius="8"
                                    BackgroundColor="#E57373"
                                    TextColor="White"
                                    HorizontalOptions="End"
                                    VerticalOptions="Start"
                                    Margin="10,0,0,0" />

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>
    </Grid>
</ContentPage>